rules_version = '2';

// MVP rules for Divvy.
//
// The app is designed with no user accounts (see CLAUDE.md: "Auth: None for
// MVP. Users identify by name only within a session."). Anyone with a session
// code can read and write to the three collections used by the app. Sessions
// are expected to expire after 24 hours; configure Firestore TTL policies on
// `sessions.expires_at` and `receipts.scanned_at` to auto-clean stale data.
//
// Deploy with:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
    match /receipts/{receiptId} {
      allow read, write: if true;
    }
    match /claims/{claimId} {
      allow read, write: if true;
    }
  }
}
